---
import DocLayout from "@/layouts/doc-layout.astro";
import { settings } from "@/config/settings";
import { withBase } from "@/utils/base";
import { buildNavTree, groupSatelliteNodes, isNavVisible } from "@/utils/docs";
import { loadLocaleDocs } from "@/utils/locale-docs";
import SiteTreeNav from "@/components/site-tree-nav.tsx";

const ctaNav = settings.headerNav[0] ?? null;
const overview = ctaNav ? withBase(`/ja${ctaNav.path}`) : null;
const categoryOrder = settings.headerNav
  .map((n) => n.categoryMatch)
  .filter((v): v is string => !!v);

// Build full nav tree for site index
const { allDocs, categoryMeta } = await loadLocaleDocs("ja");
const navDocs = allDocs.filter(isNavVisible);
const tree = buildNavTree(navDocs, "ja", categoryMeta);
const groupedTree = groupSatelliteNodes(tree, categoryOrder);
---

<DocLayout title={settings.siteName} lang="ja" hideSidebar hideToc>
  <!-- Hero: centered single column -->
  <div class="flex justify-center mb-vsp-xl">
    <div class="flex flex-col items-center text-center gap-hsp-md">
      <div>
        <h1 class="text-heading font-futura mb-vsp-2xs">{settings.siteName}</h1>
        <p class="text-muted text-small mb-vsp-sm">
          {settings.siteDescription}
        </p>
        <div class="flex items-center justify-center gap-hsp-md text-small">
          {
            overview && (
              <>
                <a href={overview} class="text-fg underline hover:text-accent">
                  概要
                </a>
                <span class="text-muted">/</span>
              </>
            )
          }
          <a
            href="https://github.com/zudolab/zudo-doc"
            class="text-fg underline hover:text-accent"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <span class="text-muted">/</span>
          <a
            href="https://x.com/Takazudo"
            class="text-fg underline hover:text-accent"
            target="_blank"
            rel="noopener noreferrer">@Takazudo</a
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Sitemap grid -->
  <SiteTreeNav
    tree={groupedTree}
    categoryOrder={categoryOrder}
    categoryIgnore={["inbox"]}
    client:idle
  />
</DocLayout>
